{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "services/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "services/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/the-ecosystem",
      "dest": "/the-ecosystem.html"
    },
    {
      "src": "/the-impact",
      "dest": "/the-impact.html"
    },
    {
      "src": "/blogs",
      "dest": "/blogs.html"
    },
    {
      "src": "/article",
      "dest": "/article.html"
    },
    {
      "src": "/press-releases",
      "dest": "/press-releases.html"
    },
    {
      "src": "/service-details",
      "dest": "/service-details.html"
    },
    {
      "src": "/starter-page",
      "dest": "/starter-page.html"
    },
    {
      "src": "/portfolio-details",
      "dest": "/portfolio-details.html"
    },
    {
      "src": "/services/(.*)",
      "dest": "/services/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "src": "/services/cti",
      "dest": "/services/cti.html"
    },
    {
      "src": "/services/esrc",
      "dest": "/services/esrc.html"
    },
    {
      "src": "/services/gadc",
      "dest": "/services/gadc.html"
    },
    {
      "src": "/services/dtc",
      "dest": "/services/dtc.html"
    },
    {
      "src": "/services/mrc",
      "dest": "/services/mrc.html"
    },
    {
      "src": "/services/mtcc",
      "dest": "/services/mtcc.html"
    },
    {
      "src": "/services/arc",
      "dest": "/services/arc.html"
    },
    {
      "src": "/services/fic",
      "dest": "/services/fic.html"
    },
    {
      "src": "/services/sirc",
      "dest": "/services/sirc.html"
    },
    {
      "src": "/services/vip-corals",
      "dest": "/services/vip-corals.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=UTF-8"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/services/cti.html",
      "destination": "/services/cti",
      "permanent": true
    },
    {
      "source": "/services/esrc.html",
      "destination": "/services/esrc",
      "permanent": true
    },
    {
      "source": "/services/gadc.html",
      "destination": "/services/gadc",
      "permanent": true
    },
    {
      "source": "/services/dtc.html",
      "destination": "/services/dtc",
      "permanent": true
    },
    {
      "source": "/services/mrc.html",
      "destination": "/services/mrc",
      "permanent": true
    },
    {
      "source": "/services/mtcc.html",
      "destination": "/services/mtcc",
      "permanent": true
    },
    {
      "source": "/services/arc.html",
      "destination": "/services/arc",
      "permanent": true
    },
    {
      "source": "/services/fic.html",
      "destination": "/services/fic",
      "permanent": true
    },
    {
      "source": "/services/sirc.html",
      "destination": "/services/sirc",
      "permanent": true
    },
    {
      "source": "/services/vip-corals.html",
      "destination": "/services/vip-corals",
      "permanent": true
    }
  ],
  "overrides": {
    "services/*.html": {
      "headers": {
        "Content-Type": "text/html"
      }
    }
  },
  "github": {
    "silent": true
  }
}